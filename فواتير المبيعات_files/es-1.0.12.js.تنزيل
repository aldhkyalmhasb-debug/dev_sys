function get_item_sublist(grp) {

    

    if (arguments.length < 1) 
        grp = null;
    

    if (hs.isEmpty(grp))
        grp = es.itm_grp;
    
    if (hs.isEmpty(grp))
        grp = getUrlParameter("itm-grp");

    if (hs.isEmpty(grp))
        grp = null;

    var typ = es.itm_typ;
    if (hs.isEmpty(typ))
        typ = getUrlParameter("itm-typ");

    if (hs.isEmpty(typ))
        typ = null;
    
    var es_items_list = get_item_list();

    if (grp == null && typ == null)
        return es_items_list;
    else
        hs.msg.toast('showing item group: ' + grp + ' type:' + typ);

    var item_sublist = new Array();

    var i, c = 0;
    for (i = 0; i < es_items_list.length; i++) {
        var itm_grp = es_items_list[i][6], itm_typ = es_items_list[i][4];
        if ((grp == null || itm_grp == grp || grp.contains(itm_grp)) && (typ == null || itm_typ == typ || typ.contains(itm_typ)))
            item_sublist[c++] = es_items_list[i];
    };

    return item_sublist;

}




