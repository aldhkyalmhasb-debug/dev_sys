function on_item_price_changed(el) {

    var seq = getLineSeq(el);

    if (hs.isEmpty(seq))
        return;

    var is_tax_enabled = pd.VAT != 0 && h$("en_sales_tax").val() == "Y"

    var is_vat_in_sales_price = is_tax_enabled && pd.vat_in_price && use_sale_price;
    var is_simplified =  hs.fm.val("doc_group") == "02"; // review_me - support another checks
    

    var item = line_item(seq);
    var unit_price = line_price(seq);
    var units = line_qty(seq); 

    check_item_price(seq);
    
    var sub_total, seq;
   


    if (isNaN(unit_price) || unit_price < 0)
        unit_price = 0;

    if (isNaN(units) || units < 0)
        units = 0;

    if (use_hp_in_tax)
        sub_total = hs.safe.roundHP(unit_price * units);
    else
        sub_total = hs.safe.round(unit_price * units);
    

    get_sub_control("up", seq).val(hs.fmtAmountHP(unit_price,!0)); // item price
    get_sub_control("uc", seq).val(units != 0 ? units : ''); // item count
    line_subtotal(seq, sub_total);

    var itm_tax_pct = 0, upwtax = line_upwtax(seq);

    if (pd.VAT != 0) {
        var ltax = 0, ltaxable = 0, sbwt = sub_total;

        if (is_tax_enabled && item != null) {

            ltaxable = sub_total;
            
            if (pd.VAT == 2) {
                ltaxable += line_unit_discount(seq) * units;
            };

            itm_tax_pct = item.item_tax_pct;
            
            

            ltax = calc_tax(ltaxable, itm_tax_pct, false);

            ltax =  hs.safe.roundHP(ltax);


            sbwt = hs.safe.round(sub_total + ltax);

            
            if (upwtax != 0 && is_vat_in_sales_price && improve_tax_ui) {
                    sbwt = upwtax * units;
                    ltax = sbwt - sub_total;
            };
            
            
            
        }
       
        get_sub_control("rn", seq).val(hs.fmtAmount(sbwt, !0)); // total with tax
        
       

        line_tax(seq, ltax);
