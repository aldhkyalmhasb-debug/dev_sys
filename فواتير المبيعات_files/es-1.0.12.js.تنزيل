function get_first_vacant_doc_line_seq(fld_key, sub_fld_key) {

    
    
    var i = 0;

    while (1) {
       
        var eid = getLineDocControlId(fld_key, sub_fld_key, i);
        var cur_val = hs.fm.val(eid);
        if (hs.isEmpty(cur_val))
            return i;

        i++;
    };

}

function line_finditem(item_id) { // return seq

    var b = 0; // consequtive blank

    for (var i = 0; i < es_doc_line_count; i++) {
        var l_item_id = line_item_id(i);

        if (hs.isEmpty(l_item_id))
            b++;
        else {
            if (l_item_id == item_id)
                return i;
            b = 0;
        }

        if (b == 5)
            break; 
    };

    return -1; // not found

}

function fill_doc_line_items(fld_key, sub_fld_key, csv, apply_select, chk_existing) {

    if (arguments.length < 4)
        apply_select = false;

    if (arguments.length < 5)
        chk_existing = false;

    var arr_vals = csv.split(';');

    var l = get_first_vacant_doc_line_seq(fld_key, sub_fld_key);
    var i = 0, eid;

    for (var i = 0; i < arr_vals.length; i++) {

        var item_id = arr_vals[i];
        if (chk_existing) {
            var idx = line_finditem(item_id);
            if (idx >= 0) {
                var m = item_id + " : موجود مسبقا @" + (idx + 1);
                eid = getLineDocControlId(fld_key, sub_fld_key, idx);

                hs.ui.scrollTo(h$(eid).offsetParent(), $(".item-list-body")[0]);

                hs.msg.tip(eid, m, 10);
                hs.msg.toast(m);
                continue;
            }
        }

        eid = getLineDocControlId(fld_key, sub_fld_key, l++);

        if (!hs.e.exists(eid)) {
            return "العناصر المختارة أكثر من عدد الأسطر المتوفرة: " + i;
            
        };
        

        var cur_val = hs.fm.val(eid);
        hs.fm.val(eid, item_id);

        if (apply_select)
           getExList(eid).select();
    };

    return null;
}
    
