function cfg_keys(line_elm) {


    $(line_elm).on("keydown", function (ev) {
        var e = $(this);
        var k = ev.which;
        var can_move = (!e.is("SELECT, .ex-list")) || ev.shiftKey; 


        if (k === K.UP && can_move) {
            hs.absorb(ev);
            var seq = hs.safe.parseInt(getLineSeq(e));
            if (seq > 0) {
                seq--;
                var id = hs.e.getId(e);
                id = adjustLineSeq(seq) + id.substr(3);
                hs.e.focus(id);
            }
        };

        if (k === K.DOWN && can_move) {
            hs.absorb(ev);
            var seq = hs.safe.parseInt(getLineSeq(e));
            if (seq < es_doc_line_count) {
                seq++;
                var id = hs.e.getId(e);
                id = adjustLineSeq(seq) + id.substr(3);
                hs.e.focus(id);
            }
        };
    });

    return line_elm;
}

function cfg_item_ctrl(eId, isMobile, use_bc, _seq) {
    var e = $('#' + eId);
   
    if (e.length == 0 || e.hasClass("_cfgd")) 
        return e;
    

    if (arguments.length < 4)
        _seq = -1;// no seq

    if (!is_item_grid) { // heavy
        var LT_FMT = "<a tabindex='-1' class='icon_{1}' href=\"javascript:{3}('{0}')\">{2}</a>";
        var extra_tools = "";

        extra_tools += LT_FMT.format(eId, "",hs.L("Stock","مخزون الصنف","Stock"), "get_item_qty_list");
        extra_tools += LT_FMT.format(eId, "", hs.L("Account/Item Trans", "عرض حركة الصنف للحساب","Transaction compte/article"), "show_cov_item_trans");
        extra_tools += LT_FMT.format(eId, "icon_add", hs.L("Add to purchase list", "إضافة إلى قائمة المشتريات المطلوبة","Ajouter à la liste d'achat"), "add_to_purch_list");

        if (hs.fm.getId() == "es-sale-rent") // get_doc_type() == '206')
            extra_tools += LT_FMT.format(eId, "", "عرض جدول الحجز", "booking.checkItem");

        if (_seq >= 0 && hs.fm.isEntry())
            extra_tools += LT_FMT.format(eId, "del", hs.R.delete + " #" + (hs.safe.parseInt(_seq) + 1), "reset_line_item");

        if (hs.fm.getId() != "hc-lab")
            hs.fm.addFieldTools(eId, "es-item", null, true, extra_tools);
    };

    e.exList({
        codelist: es_cl_items_bc,
        select_only: true,
        support_bc: use_bc, // true
