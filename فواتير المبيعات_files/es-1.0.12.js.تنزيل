var max_frac_to_auto_discount = 0.03;

function fraction_discount(is_auto) {
    var total_price = hs.safe.parseFloat($("#price").val()); // total price
    var discount = hs.safe.parseFloat($("#discount").val());

    if (total_price > 1 && discount == 0) { // auto fraction removal
        var fr = hs.safe.fract(total_price);
        if (fr != 0 && (!is_auto || fr <= max_frac_to_auto_discount)) {
            hs.msg.toast("Auto fraction Discount: " + fr, 5);
            $("#discount").val(hs.fmtAmount(fr));
        }
    }
}

function adjustRound(amount) {
    var fr = hs.safe.fract(amount);
    if (fr == 0.01) {
        amount -= 0.01;
    }
    else
        if (fr == 0.99) {
            amount += 0.01;
        }

    return amount;

}

function on_discount_changed(is_actual_change) {

  

    if (is_actual_change) {
        if (auto_round_in_doc_charges)
            $("#doc_charges").val("");
        doc_rounding_amount = 0;
        auto_round_in_doc_charges = auto_round_in_discount = false;
    }

   

    var $discount = $("#discount"),
    is_pct = $discount.val().contains("%"),
    is_std_pct = !($discount.val().contains("%%")),
    total_price = hs.safe.parseFloat($("#price").val()),
    discount = hs.safe.parseFloat($discount.val()),
    is_after_tax = discount > 0 && !is_pct && $discount.val().contains("*");

    // test ksa
    if (is_after_tax) {

        var taxable_cats = getDocTaxableCats(), doc_tot_with_tax = 0, tot_cats_discount = 0;

        taxable_cats.forEach((cat_tabxable, cat_pct) => {
            doc_tot_with_tax += cat_tabxable + calc_tax(cat_tabxable, cat_pct);
        });



        taxable_cats.forEach((cat_tabxable, cat_pct) => {

            var lpct = (cat_tabxable + calc_tax(cat_tabxable, cat_pct)) / doc_tot_with_tax,
                inv_pct = hs.safe.roundHP(100 / (100 + cat_pct));


            tot_cats_discount += discount * lpct * inv_pct;

        });

        discount = tot_cats_discount;


        //      discount = hs.safe.round(discount * 0.8695652); // 0.869565217391304; //


        $("#discount").val(hs.fmtAmount(discount));
        hs.msg.toast("تخفيض من اجمالي الفاتورة سيتم اعادة احتساب مبلغ التخفيض", 5);
    }
      // end test ksa

    

    
   
    var discount_base = total_price;
       

    discount_base = calc_items_total_discount_base_dc();
    

    if (is_pct) {
        discount = hs.safe.round(get_amount_discount(discount_base, discount, false, is_std_pct));
        $("#discount").val(hs.fmtAmount(discount));
    }

    var doc_charges = parseFloatOrPctOf("doc_charges", "price");
     
         

    if (pd.VAT==0 && !is_actual_change && pd.hasOption(0x0010) && total_price > 1 && get_doc_crncy() == es.CC)  // auto fraction removal
        fraction_discount(1);
    
    

    if (pd.VAT == 1)
        calc_vat_after_discount(is_actual_change);


    

    var tax_amount = hs.safe.parseFloat($("#tax_amount").val());


    var net_amount = hs.safe.round(total_price + doc_charges - discount + tax_amount);

   
    // beta - check_me
    
    if (is_after_tax && pd.VAT == 1) {
        var fr = hs.safe.fract(net_amount);
        if (fr == 0.01) {
            net_amount -= 0.01;
            discount += 0.01;
            $("#discount").val(hs.fmtAmount(discount));
            hs.msg.toast("Discount +0.01", 5);
        }
        else
            if (fr == 0.99) {
                net_amount += 0.01;
                discount -= 0.01;
                $("#discount").val(hs.fmtAmount(discount));
                hs.msg.toast("Discount -0.01", 5);
            }
    };
    // end beta

    


    $("#net_amount").val(hs.fmtAmount(net_amount));
    
    var pnet_amnt = parseFloatOrPctOf("pnet_amount", "net_amount");

    if (net_amount != 0 &&  pnet_amnt == net_amount ) {
        $("#doc_subtype").val("04");
      //  $("#cash_id").val('');
    };

    if (is_cash_invoice()) {

        pnet_amnt += hs.safe.parseFloat($("#num02").val());

        if (net_amount - pnet_amnt > 0)
            $("#paid").val(hs.fmtAmount((net_amount - pnet_amnt)));
        else
            $("#paid").val("0");

        $("#rem_amount").val("0");
    };
   

    on_paid_changed();
}

