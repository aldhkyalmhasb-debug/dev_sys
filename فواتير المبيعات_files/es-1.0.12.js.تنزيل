        def_sale_unit: a[8],
        item_crncy: a[9],

        u1_id: a[10],
        u1_price: a[11],
        u1_cost: a[12],
        u1_min_price: a[13],

        u2_id: a[14],
        u2_price: a[15],
        u2_cost: a[16],
        u2_min_price: a[17],

        u3_id: a[18],
        u3_price: a[19],
        u3_cost: a[20],
