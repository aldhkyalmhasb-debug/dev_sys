    $("#discount, #doc_charges, #pnet_amount, #paid, #num02").val("");

    for (seq = 0; seq < es_doc_line_count; seq++) {
        var item_id = line_item_id(seq);
        if (!hs.isEmpty(item_id)) {
            get_sub_control("di", seq.toString()).val("");
     
            if ( to_cc || is_fc) {
                var price= line_price(seq);
                if (to_cc)
                    price = convert_amount_to_cc(price, crncy_code);
                else
                    price = convert_currency(price, es.CC, crncy_code);
                
                line_price$(seq).val(hs.safe.roundHP(price).toString());
                //line_price$(seq).val(hs.safe.round(price).toString());
            }
            else
                on_item_unit_changed(get_sub_control("un", seq.toString()), seq);

            if (line_price(seq) <= 0)
