        };
    };


    if (!hs.e.isReadonly("doc_crncy_exrate"))
        $("#doc_crncy_exrate").attr('placeholder', crncy_exrate);


    if (is_fc)
        es_doc_recalc();

    if (to_cc) {
        $("#doc_crncy_exrate").val("").hide();
        $("#doc_crncy").val(es.CC);
        es_doc_recalc();
    };

    hs.msg.tip(crncy_lst, "بسبب تغيير العملة، سيتم تصفير المبالغ (المدفوعة/التخفيض/الأعباء)  في المستند", 8);
}

