function calc_items_total_cost_dc() {

    

    var tot_cost = 0;
    for (var seq = 0; seq < es_doc_line_count; seq++) {
        var item = line_item(seq), unit = line_unit(seq);
        var tot_qty = line_qty(seq) + line_free(seq);

       
        tot_cost += (get_item_unit_cost(item, unit) * tot_qty);
       

    };

    return convert_currency(tot_cost, es.SC, get_doc_crncy());

    
}

function calc_items_total_discount_base_dc() {
    var tot_cost = 0;
    for (var seq = 0; seq < es_doc_line_count; seq++) {
        var item = line_item(seq), unit = line_unit(seq);
        var tot_qty = line_qty(seq) + line_free(seq);

        if (item == null || hs.isFlagEnabled(item.item_flags, 0x0800))
            continue; // no discount allowed

        if (pd.hasOption(0x0020))  // use cost instead of price
            tot_cost += (get_item_unit_cost(item, unit) * tot_qty);
        else
            tot_cost += line_subtotal(seq);
    };

    return convert_currency(tot_cost, es.SC, get_doc_crncy());


}



function calc_tax(price, tax_pct, _tax_in_price) {

    if (arguments.length < 3)
        _tax_in_price = false;

    if (_tax_in_price)
        return price - (price / ((100 + tax_pct) / 100));
    else
        return price * tax_pct / 100;
}

function getDocTaxableCats() {

    var taxable_cats = new Map();

    for (var seq = 0; seq < es_doc_line_count; seq++) {
        var item = line_item(seq);
        if (item != null) {
            var lTaxable = line_taxable(seq, null);

            taxable_cats.set(item.item_tax_pct, lTaxable + (taxable_cats.get(item.item_tax_pct) || 0));
        };

    } // for

    return taxable_cats;
}


function calc_vat_after_discount(is_actual_change) {

    if (auto_round_in_discount)
        return; 

    if (pd.VAT != 1)
        return;

    var is_simplified = true;// hs.fm.val("doc_group") == "02"; // review_me - support another checks

    if (!use_sale_price)
        is_simplified = true;

    if (!is_simplified)
        return; //  due KSA - to be checked for others // line_unit_discount field should be added

    
    var is_tax_enabled =  h$("en_sales_tax").val() == "Y"

    var doc_discount = hs.safe.parseFloat($("#discount").val());
    var doc_price = hs.safe.parseFloat($("#price").val());

    if (doc_price <= 0)
        return;

    

   

    if (doc_discount > 0 && doc_discount < 0.05)
        return;


    var taxable_cats = new Map();

    var total_tax = 0;

    if (is_tax_enabled) {
        for (var seq = 0; seq < es_doc_line_count; seq++) {
            var ltax = 0;
            var item = line_item(seq);
            if (item != null && item.item_tax_pct != 0) {
                var tax_off = 0, lTaxable = line_taxable(seq, item);
                var lpct = lTaxable / doc_price;

                ltax = calc_tax(lTaxable, item.item_tax_pct);

                taxable_cats.set(item.item_tax_pct, lTaxable + (taxable_cats.get(item.item_tax_pct) || 0));


                if (doc_discount != 0)
                    tax_off = calc_tax(doc_discount * lpct, item.item_tax_pct);

                //get_sub_control("nt", seq).attr("placeholder", "tax off:" + hs.fmtAmount(tax_off, !0));

                ltax -= tax_off;

             //   ltax=hs.safe.round(ltax);

                
            };

          
            total_tax += ltax;
        } // for
    } // if


    var cats_total_tax = 0;
    taxable_cats.forEach((cat_tabxable, cat_pct) => {

        var lpct = cat_tabxable / doc_price, cat_taxable_off = 0;

        if (doc_discount != 0) {
            cat_taxable_off = doc_discount * lpct;
            cat_tabxable -= cat_taxable_off;
        }

        cats_total_tax += hs.safe.round(calc_tax(cat_tabxable, cat_pct, false));
    });

    cats_total_tax = hs.safe.round(cats_total_tax);

//    var diff_tax = total_tax - cats_total_tax;
  //  hs.msg.toast("Diff Tax after Discount: " + hs.safe.roundHP(diff_tax) + " Cats=" + taxable_cats.size, 5, true);


    total_tax = cats_total_tax; // + doc_rounding_amount;



    $("#tax_amount").val(hs.fmtAmount(total_tax, !1));

   


}





