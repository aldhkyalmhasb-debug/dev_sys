function get_item_unit_cost(itm, u) { // in SC
    if (itm != null) {
        if (u == itm.u1_id) return hs.safe.parseFloat(itm.u1_cost);
        if (u == itm.u2_id) return hs.safe.parseFloat(itm.u2_cost);
        if (u == itm.u3_id) return hs.safe.parseFloat(itm.u3_cost);
    }

    return 0;
}

function get_item_price_without_tax(itm, pwtax) {
    if (itm != null) {
        var tax = calc_tax(pwtax, itm.item_tax_pct, true);

        if (use_hp_in_up)
            pwtax = hs.safe.roundHP(pwtax - tax);
        else
            pwtax = hs.safe.round(pwtax - tax);
    };
    return pwtax;
}


function get_item_unit_price_ex(itm, u, pricing) {
    var up = 0;

    if (u == itm.u1_id) {
        if (pricing == "S1") up = itm.u1_price_s1;
        else
            if (pricing == "S2") up = itm.u1_price_s2;
            else
                if (pricing == "S3") up = itm.u1_price_s3;
                else
                    up = itm.u1_price;
    }
    else
    if (u == itm.u2_id) {
        if (pricing == "S1") up = itm.u2_price_s1;
        else
            if (pricing == "S2") up = itm.u2_price_s2;
            else
                if (pricing == "S3") up = itm.u2_price_s3;
                else
                    up = itm.u2_price;
    }
        else
        if (u == itm.u3_id) {
            if (pricing == "S1") up = itm.u3_price_s1;
            else
                if (pricing == "S2") up = itm.u3_price_s2;
                else
                    if (pricing == "S3") up = itm.u3_price_s3;
                    else
                        up = itm.u3_price;
            };

    return up;



}


function get_item_unit_price(itm, u, exclude_tax) { // in SC

    var doc_subtype = hs.fm.val("doc_subtype"), pricing = hs.fm.val("pricing") || "";
    var is_wholesale = doc_subtype == "05" || doc_subtype == "06" || doc_subtype == "07" ||   pricing == "S0";
    var up = 0;

    if (itm != null) {
        if (u == itm.u1_id) up = hs.safe.parseFloat(is_wholesale ? itm.u1_min_price : get_item_unit_price_ex(itm, u, pricing));
        else if (u == itm.u2_id) up = hs.safe.parseFloat(is_wholesale ? itm.u2_min_price : get_item_unit_price_ex(itm, u, pricing));
        else if (u == itm.u3_id) up = hs.safe.parseFloat(is_wholesale ? itm.u3_min_price : get_item_unit_price_ex(itm, u, pricing));

        if (exclude_tax && up != 0 && pd.vat_in_price) 
        {
            var unit_tax = calc_tax(up, itm.item_tax_pct, true);
            up = up - unit_tax;

            if (use_hp_in_up)
                up = hs.safe.roundHP(up); // config_me
            else
                up = hs.safe.round(up); // config_me

            
        };

    };

    return up;
}

function on_upwtax_changed(e) {
    var seq = getLineSeq(e);
    var o = dl_e("ux", seq);

    if (hs.e.isReadonly(o))
        return;

    var upwt = line_upwtax(seq);
    if (upwt <= 0) {
        hs.msg.required(o);
        return;
    };


    var itm = line_item(seq);
    if (itm == null) {
        hs.msg.required(dl_e("id", seq));
        return;
    };
       

    var tax = calc_tax(upwt, itm.item_tax_pct, true);

   
    on_item_price_changed(line_price(seq, use_hp_in_up ? hs.safe.roundHP(upwt - tax) : hs.safe.round(upwt - tax)));
    
}


function on_withtax_change(e) {
    var seq = getLineSeq(e);
    var o = dl_e("rn", seq);

    if (hs.e.isReadonly(o)) 
        return;

    var stwt = line_subtotal_withtax(seq);
    if (stwt <= 0) {
        hs.msg.required(o);
        return;
    };

    
    var itm = line_item(seq);
    if (itm == null) {
        hs.msg.required(dl_e("id", seq));
        return;
    };

    var qty = line_qty(seq);
    if (qty <= 0)
        qty = 1;

    line_upwtax(seq, stwt / qty);

    var tax = calc_tax(stwt, itm.item_tax_pct, true);

    var up = hs.safe.roundHP(stwt - tax) / qty;
    on_item_price_changed(line_price(seq, up));

}


function is_in_csv_codes(codes_csv, code) {
    if (hs.isEmpty(codes_csv) || hs.isEmpty(code))
        return false;

    if (!codes_csv.contains(";"))
        return codes_csv == code;

    codes_csv = ";" + codes_csv + ";"
    code = ";" + code + ";";
    return codes_csv.indexOf(code) >= 0;
}

function get_item_by_code(code) {
    if (hs.isEmpty(code))
        return null;

    var es_items_list = get_item_list();
    var i;
    for (i = 0; i < es_items_list.length; i++) {
       //  if (es_items_list[i][2] == code)
        if (is_in_csv_codes(es_items_list[i][2],code)) // to support multi-barcodes
            return parseItem(es_items_list[i]);
    };

    return null;
}


