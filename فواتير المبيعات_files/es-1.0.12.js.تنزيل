function on_sales_doc_currency_changed(crncy_lst, confirmed, to_cc) {

    // if (!use_sale_price) return;

    if (!hs.fm.isEntry())
        return;

    

    if (arguments.length < 2) 
        confirmed = false;

    if (arguments.length < 3)
        to_cc = false;

   // if (use_sale_price)
       // confirmed = true;

    if (crncy_lst == null)
        crncy_lst = "doc_crncy";
    
    var crncy_code = h$(crncy_lst).val();

    if (hs.isEmpty(crncy_code))
        return;

    var crncy_exrate = get_exchange_rate(crncy_code);
    

    var is_fc = crncy_code != es.CC;

    if (to_cc) {
        confirmed = true;
    }

    
    if (!confirmed) {
        ConfirmUrl("javascript:on_sales_doc_currency_changed(null,true,false)",
            is_fc ? "هل تريد تحويل كل المبالغ والأسعار إلى العملة الجديدة بحسب سعر التحويل المحدد في الفاتورة: " + crncy_exrate : "تغيير الأسعار في المستند إلى الأسعار المحددة في بيانات الأصناف");
