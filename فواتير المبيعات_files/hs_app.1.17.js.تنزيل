    var url = "/app/?" + sel_cmd + "&p1=" + $(ctl_p1_id).val() + "&p2=" + $(ctl_p2_id).val() + "&target=" + ctl_target_id + ctl_p3_id + ctl_p4_id + ctl_p5_id;

