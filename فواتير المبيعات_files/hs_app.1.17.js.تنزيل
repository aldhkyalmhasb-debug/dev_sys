function getGeoLocation(e) {

    if (isApp) {
        sendToApp("get-geo-loc", "e-id=" + hs.e.getId(e));
        
        return;
    };

    if (navigator.geolocation) {
        h$(e).val('');
        hs.e.loading(e);
        navigator.geolocation.getCurrentPosition(
            function (pos) {
                hs.e.loading(e,false);
                var crd = pos.coords;
                h$(e).val(crd.latitude + ", " + crd.longitude);
                hs.msg.tip(e, "Location: " + crd.latitude + ", " + crd.longitude + " &pm;" + crd.accuracy + " meters");
            },
            function (err) {
                hs.e.loading(e, false);
                hs.msg.tip(e, "Error " + err.code + " : " + err.message);
            }
        )
    }
    else {
        hs.msg.tip(e, "Geolocation is not supported by this browser");
    }

}


