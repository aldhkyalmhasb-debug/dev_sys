        query: async function (fm_id, fm_data, opt) {

            try {
                fm_data = fm_data || new FormData();
                opt = opt || {};

                opt.fm_mode = opt.fm_mode || ''
                opt.data_mode = opt.data_mode || ''



                if (opt.page_size === undefined) opt.page_size = 500;


                if (opt.page_size > 0) fm_data.append("page_size", opt.page_size);
                if (opt.printable) fm_data.append("data_fmt", "Y");
