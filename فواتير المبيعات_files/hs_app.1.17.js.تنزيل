function flds_order_push(id) {
    if (flds_order != null && hs.e.exists(id))
        flds_order.push(id)
}

function try_focus(e) {
    e = h$(e);
    if (($(e).is(":hidden, :disabled, [readonly='readonly']"))
        || ($(e).attr("tabindex") == "-1")
        || (!$(e).is(":input, a"))) return false;

    var vlen = hs.len($(e).val());

    if (vlen > 0 && $(e).is("input[type='text']")) {
        $(e).focus().select();
      //  hs.e.getElem(e).setSelectionRange(vlen, vlen);
    }
    else
        $(e).focus().select();

    
    return true;
}

function set_focus_after(i) {
   
    var ii = i;

    if (flds_order == null) 
        return;
       
    while (++i < flds_order.length) {
        if (try_focus(h$(flds_order[i])))
            return;
    };

   

    if ((ii > 0) && isAutoFormSubmit) {
        if (hs.isInEditMode()) 
            ConfirmUrl("javascript:DoSubmit()", hs.L("Save", "حفظ","Sauvegarder"));
        else
            DoSubmit();
    }
}


