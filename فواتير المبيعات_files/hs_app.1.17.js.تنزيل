                    title = items[i][1] + " - " + items[i][0];
                else
                    title = items[i][1];

            $(e).append($('<option />').val(items[i][0]).html(title));
        }
         
       // hs.list.val(e, sel_id); 
        if (keep_value)
            hs.fm.exListValue(hs.e.getId(e), sel_id, sel_text); // restore the selected id - 1.10.2019
            
    };
