var hsWin = {

    win: null,

    show: function (url, winName) {

        if (winName == null)
            winName = "";

        if (!url.contains("?"))
            url += "?";

       
        if (!url.contains("ui-wnd="))
            url += "&ui-wnd=" + winName;

        if (!url.contains("sind=y"))
            url += "&sind=y";

       // this.close();
        this.win = window.open(url, winName, "fullscreen=yes,scrollbars=yes,menubar=yes");
        this.win.focus();
        
    },

    close: function () {
        if (this.win != null)
            this.win.close();
        this.win = null;
    },

};



