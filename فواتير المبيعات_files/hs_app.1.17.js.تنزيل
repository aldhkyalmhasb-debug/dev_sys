            if (this._showTimerId != null) {
                window.clearTimeout(this._showTimerId);
                //showExListTimerId = 0;
            };

            this._listDiv.hide();

            this.options.support_bc = this.saved_support_bc;
            this.element.removeClass('find-mode');

            if (was_open)
                this.trace("exlist.closed");

        },

