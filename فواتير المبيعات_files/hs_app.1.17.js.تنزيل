function decodeURI(u) {
    try
    {
        u = decodeURIComponent(u);
    }
    catch (e) {hs.logEx(e) }

    return u;
}

function pageUrl() {
    return location.href;
}

function pageQry() {
    return location.search.substring(1); 

    // return spa_mode < 2 ? location.search.substring(1) : location.hash;
}

function getUrlParameter(sParam) {
    
    var sParams = decodeURI(pageQry()).split('&'),
        kv,
        i;

    for (i = 0; i < sParams.length; i++) {
        kv = sParams[i].split('=');

        if (kv[0] === sParam) {
            return kv[1] === undefined ? '' : kv[1];
            //return sParameterName[1] === undefined ? true : sParameterName[1];
        }
    }
};


function applyUrlInitsValues() {

    if (!is_dirty && getUrlParameter("init-values-clt") == "y") { // not posted back

        var sParams = decodeURI(pageQry()).split('&'),
            kv, k, v, i;

        for (i = 0; i < sParams.length; i++) {
            kv = sParams[i].split('=');
            k = kv[0];

            if (k.startsWith("i-")) {
                k = k.substring(2);
                $("#" + k).val(kv[1]);
            }
        }
    }
};


