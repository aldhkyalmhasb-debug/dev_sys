function svg_icon_get(icon) {
    for (const value of svg_arr_icons) {
        if (value[0] == icon)
            return value; 
    }
    return null;
}

function svg_icon(icon) {

    var icon_data = svg_icon_get(icon);
    if (icon_data == null)
        return "";

    var fill = icon_data[1],
        stroke = icon_data[2] || fill,
        path = icon_data[3],
        size = icon_data[4] || "24 24";

    if (!hs.isEmpty(stroke)) stroke = " stroke='" + stroke + "'";
    if (!hs.isEmpty(fill)) fill += " fill='" + fill + "'";

    return "<svg focusable='false' xmlns='http://www.w3.org/2000/svg' viewBox='0 0 " + size + "'" + fill + stroke + "><path d='" + path + "'></path></svg>";

    
}



function svg_icons() {
