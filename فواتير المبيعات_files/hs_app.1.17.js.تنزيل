           this.trace("item_code=" + item_code + " prev=" + this._prev_code);

            if (is_page_loaded)
            {
                if (item_code != this._prev_code) {
                    hs.fm.dirty(true);
                    if (this.options.on_item_changed != null)
                        this.options.on_item_changed(this.element, move_next);
                    else {
                        focus_next(this.element);
                    }
                }
