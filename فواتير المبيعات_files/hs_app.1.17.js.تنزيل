        var items = this._items;
        if (items == null) {
            hs.trace("null items list in fillSelectList: " + hs.e.getId(e),7);
            return;
        };

        var i;
        var title;

        if (reset_list) 
            hs.list.empty(e);
        
        

        for (i = 0; i < items.length; i++) {
            if (show_codes == 1)
                title = items[i][0] + " - " + items[i][1];
            else
